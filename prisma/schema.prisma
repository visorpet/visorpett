generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  phone         String?
  role          UserRole  @default(CLIENTE)
  passwordHash  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  groomer       Groomer?
  pets          Pet[]
  petShop       PetShop?
  sessions      Session[]
}

model PetShop {
  id           String        @id @default(cuid())
  name         String
  slug         String        @unique
  logoUrl      String?
  phone        String?
  address      String?
  city         String?
  state        String?
  ownerId      String        @unique
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  clients      Client[]
  groomers     Groomer[]
  messageLogs  MessageLog[]
  owner        User          @relation(fields: [ownerId], references: [id])
  services     Service[]
  subscription Subscription?

  @@index([slug])
}

model Subscription {
  id                   String             @id @default(cuid())
  petShopId            String             @unique
  plan                 SubscriptionPlan   @default(FREE)
  status               SubscriptionStatus @default(TRIALING)
  stripeCustomerId     String?            @unique
  stripeSubscriptionId String?            @unique
  stripePriceId        String?
  currentPeriodStart   DateTime?
  currentPeriodEnd     DateTime?
  cancelAtPeriodEnd    Boolean            @default(false)
  createdAt            DateTime           @default(now())
  updatedAt            DateTime           @updatedAt
  petShop              PetShop            @relation(fields: [petShopId], references: [id])
}

model Groomer {
  id           String        @id @default(cuid())
  name         String
  phone        String?
  photoUrl     String?
  petShopId    String
  userId       String?       @unique
  createdAt    DateTime      @default(now())
  appointments Appointment[]
  petShop      PetShop       @relation(fields: [petShopId], references: [id])
  user         User?         @relation(fields: [userId], references: [id])

  @@index([petShopId])
}

model Client {
  id          String       @id @default(cuid())
  name        String
  email       String?
  phone       String
  petShopId   String
  userId      String?
  createdAt   DateTime     @default(now())
  petShop     PetShop      @relation(fields: [petShopId], references: [id])
  messageLogs MessageLog[]
  pets        Pet[]

  @@index([petShopId])
  @@index([phone])
}

model Pet {
  id           String        @id @default(cuid())
  name         String
  species      String
  breed        String?
  birthDate    DateTime?
  weight       Float?
  photoUrl     String?
  notes        String?
  clientId     String
  ownerId      String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  appointments Appointment[]
  medicalNotes MedicalNote[]
  messageLogs  MessageLog[]
  client       Client        @relation(fields: [clientId], references: [id])
  owner        User?         @relation(fields: [ownerId], references: [id])
  vaccines     Vaccine[]

  @@index([clientId])
  @@index([ownerId])
}

model Vaccine {
  id        String    @id @default(cuid())
  petId     String
  name      String
  appliedAt DateTime
  nextDueAt DateTime?
  vetName   String?
  createdAt DateTime  @default(now())
  pet       Pet       @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
}

model MedicalNote {
  id        String   @id @default(cuid())
  petId     String
  note      String
  author    String
  createdAt DateTime @default(now())
  pet       Pet      @relation(fields: [petId], references: [id], onDelete: Cascade)

  @@index([petId])
}

model Service {
  id           String        @id @default(cuid())
  petShopId    String
  type         ServiceType
  label        String
  price        Float
  durationMin  Int
  active       Boolean       @default(true)
  createdAt    DateTime      @default(now())
  appointments Appointment[]
  petShop      PetShop       @relation(fields: [petShopId], references: [id])

  @@index([petShopId])
}

model Appointment {
  id         String            @id @default(cuid())
  petId      String
  petShopId  String
  serviceId  String
  groomerId  String?
  date       DateTime
  status     AppointmentStatus @default(agendado)
  notes      String?
  totalPrice Float
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt
  groomer    Groomer?          @relation(fields: [groomerId], references: [id])
  pet        Pet               @relation(fields: [petId], references: [id])
  petShop    PetShop           @relation(fields: [petShopId], references: [id])
  service    Service           @relation(fields: [serviceId], references: [id])

  @@index([petShopId])
  @@index([petId])
  @@index([date])
  @@index([status])
}

model MessageLog {
  id        String   @id @default(cuid())
  petShopId String
  petId     String
  clientId  String
  type      String
  prompt    String
  response  String
  status    String   @default("sent")
  createdAt DateTime @default(now())
  client    Client   @relation(fields: [clientId], references: [id])
  pet       Pet      @relation(fields: [petId], references: [id])
  petShop   PetShop  @relation(fields: [petShopId], references: [id])

  @@index([petShopId])
  @@index([petId])
  @@index([clientId])
}

enum UserRole {
  CLIENTE
  DONO
  SUPER_ADMIN
}

enum SubscriptionPlan {
  FREE
  PRO
  PREMIUM
  ENTERPRISE
}

enum SubscriptionStatus {
  ACTIVE
  TRIALING
  PAST_DUE
  CANCELLED
}

enum AppointmentStatus {
  agendado
  confirmado
  em_atendimento
  concluido
  cancelado
  faltou
}

enum ServiceType {
  banho
  tosa
  banho_e_tosa
  consulta
  vacina
  outro
}

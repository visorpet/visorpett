{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "outputDirectory": ".next",
  "crons": [
    {
      "path": "/api/cron/retorno",
      "schedule": "0 12 * * *"
    },
    {
      "path": "/api/cron/lembretes",
      "schedule": "0 21 * * *"
    },
    {
      "path": "/api/cron/pos-atendimento",
      "schedule": "0 * * * *"
    }
  ]
}
